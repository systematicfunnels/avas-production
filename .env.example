# =============================================================
# AVAS — Environment Variables
# Copy this file to .env and fill in all values before running
# NEVER commit .env to version control
# =============================================================

# ---- App ----
APP_ENV=production
APP_SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_32
APP_DEBUG=false
APP_CORS_ORIGINS=["http://localhost:3000","https://yourdomain.com"]

# ---- Database ----
POSTGRES_USER=avas_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=avas_db
DATABASE_URL=postgresql+asyncpg://avas_user:CHANGE_ME_strong_password@postgres:5432/avas_db

# ---- Redis ----
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_URL=redis://:CHANGE_ME_redis_password@redis:6379/0

# ---- Object Storage (MinIO / S3-compatible) ----
MINIO_ROOT_USER=CHANGE_ME_minio_user
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_INSPECTIONS=avas-inspections
MINIO_BUCKET_RESULTS=avas-results
MINIO_USE_SSL=false

# ---- AI Service ----
AI_SERVICE_URL=http://ai_service:8001
AI_INFERENCE_TIMEOUT=120
AI_MAX_IMAGE_SIZE_MB=50
AI_BATCH_SIZE=8
AI_CONFIDENCE_THRESHOLD=0.5

# ---- OpenAI (optional: for report generation) ----
OPENAI_API_KEY=sk-CHANGE_ME

# ---- JWT Auth ----
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_-hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---- Frontend ----
REACT_APP_API_URL=http://localhost:8000
REACT_APP_APP_NAME=AVAS

# ---- Email (for notifications) ----
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=noreply@yourdomain.com

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
